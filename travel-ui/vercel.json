{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://travel-risk-api-production.up.railway.app/api/:path*" },
    { "source": "/trip", "destination": "https://travel-risk-api-production.up.railway.app/trip" },
    { "source": "/risk/:path*", "destination": "https://travel-risk-api-production.up.railway.app/risk/:path*" },
    { "source": "/health", "destination": "https://travel-risk-api-production.up.railway.app/health" },
    { "source": "/map/:path*", "destination": "https://travel-risk-api-production.up.railway.app/map/:path*" },
    { "source": "/gps/:path*", "destination": "https://travel-risk-api-production.up.railway.app/gps/:path*" },
    { "source": "/traffic/:path*", "destination": "https://travel-risk-api-production.up.railway.app/traffic/:path*" },
    { "source": "/weather/:path*", "destination": "https://travel-risk-api-production.up.railway.app/weather/:path*" },
    { "source": "/debug/:path*", "destination": "https://travel-risk-api-production.up.railway.app/debug/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
