# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real secrets.

# --- TrackAsia (route polyline fallback) ---
TRACKASIA_KEY=
TRACKASIA_BASE=https://maps.track-asia.com

# --- SerpAPI (Google Maps search + directions, required for /trip and /traffic/route) ---
# Comma-separated list to support key rotation, e.g. "key1,key2"
SERPAPI_KEYS=

# --- Auth (JWT) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# --- Air quality (OpenWeatherMap Air Pollution API, free tier) ---
# Get a key at https://openweathermap.org/api/air-pollution
OPENWEATHERMAP_API_KEY=

# --- Web Push (VAPID) ---
# Generate with: python scripts/generate_vapid_keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:you@example.com
